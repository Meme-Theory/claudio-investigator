# ClAudio Investigator — local development env
# Copy to `.env` and fill in. Never commit `.env`.

# =============================================================================
# REQUIRED (minimum to run the agent end-to-end against the implemented tools)
# =============================================================================

# Claude API — the agent itself
ANTHROPIC_API_KEY=

# YouTube Data API v3 — get_youtube_channel
# Create key: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in the project first or it won't appear in the
# API restrictions dropdown. Free tier: 10,000 quota units/day.
YOUTUBE_API_KEY=

# Genius (lyrics) — get_genius_lyrics
# Create client: https://genius.com/api-clients
# Note: API returns song metadata + URLs only. Lyric *text* is not exposed
# through the API; the `gpt-lyric-patterns` marker can't be flagged from
# this tool alone without scraping.
GENIUS_TOKEN=

# =============================================================================
# NO ACCOUNT NEEDED — these tools work out of the box
# =============================================================================
# iTunes Search API:  no auth, no key — lookup_itunes
# MusicBrainz:        no auth, no key — lookup_musicbrainz (UA below is encouraged)

# MusicBrainz requires a descriptive User-Agent per their policy. Defaults are
# fine for local dev; override per-deployment to identify your fork.
MUSICBRAINZ_USER_AGENT=ClAudioInvestigator/0.0.1 (+https://github.com/Meme-Theory/claudio-investigator)

# =============================================================================
# OPTIONAL — implemented tools that need free developer accounts
# =============================================================================
# Without these, the corresponding tools error gracefully and the agent skips
# them. Fewer signals available but the agent still functions.

# Discogs personal token: https://www.discogs.com/settings/developers
DISCOGS_TOKEN=

# Last.fm: https://www.last.fm/api/account/create
LASTFM_API_KEY=

# =============================================================================
# REMOVED 2026-05-18 — Spotify Web API now requires the app owner to hold a
# Spotify Premium subscription. We don't. `popularity-follower-mismatch` runs
# on Deezer fans / Last.fm listeners instead; `suno-duration-cap` runs on
# Deezer top-track durations + YouTube video durations. If you re-add Spotify
# later, restore the tool module and re-register it in tools/__init__.py.
# =============================================================================

# =============================================================================
# GITHUB (only consumed by the Actions workflows, not local CLI)
# =============================================================================
# Locally, `gh` CLI auth handles GitHub access; you only set these in CI.
GH_TOKEN=
GH_REPO=

# =============================================================================
# Runtime knobs — optional overrides
# =============================================================================
# Sane defaults live in investigator/budget.py and investigator/agent.py.
# AUTO_MERGE_THRESHOLD=0.90
# MAX_USD_PER_INVESTIGATION=0.50
# MAX_ITERATIONS=12
