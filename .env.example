# ClAudio Investigator — local development env
# Copy to `.env` and fill in. Never commit `.env`.

# --- Claude API (required for agent loop) ---
ANTHROPIC_API_KEY=

# --- Spotify (client-credentials flow) ---
# Create app: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- YouTube Data API v3 ---
# Create key: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# --- Discogs ---
# Personal access token: https://www.discogs.com/settings/developers
DISCOGS_TOKEN=

# --- Last.fm ---
# Apply: https://www.last.fm/api/account/create
LASTFM_API_KEY=

# --- Genius (lyrics) ---
# Create client: https://genius.com/api-clients
GENIUS_TOKEN=

# --- MusicBrainz ---
# No auth, but a descriptive UA is required by their policy.
MUSICBRAINZ_USER_AGENT=ClAudioInvestigator/0.0.1 ( https://github.com/TBD )

# --- GitHub (for Actions only — locally use `gh` CLI auth) ---
GH_TOKEN=
GH_REPO=

# --- Runtime knobs (optional, sane defaults in code) ---
# AUTO_MERGE_THRESHOLD=0.90
# MAX_USD_PER_INVESTIGATION=0.50
# MAX_ITERATIONS=12
